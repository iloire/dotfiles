#!/bin/bash
# Category: system
# Description: Send server health metrics to Devil Watchdog
# Usage: send-watchdog-report [options]
#
# Collects disk, memory, CPU, and service metrics and sends them
# to the Devil Watchdog server report endpoint.
#
# Options (via environment variables):
#   WATCHDOG_API_KEY       - Required. API key (dw_...) from your project dashboard.
#   WATCHDOG_SERVICES      - Optional. Comma-separated systemd services to monitor (e.g. "nginx,postgres,docker").
#
# Options (via flags):
#   -v, --verbose          Enable verbose output
#   -h, --help             Show this help message
#
# Exit codes:
#   Always exits 0 to avoid breaking calling scripts.
#   Errors are logged to ~/.watchdog-report.log

WATCHDOG_URL="https://devilwatchdog.vercel.app/api/servers/report"
WATCHDOG_LOG="$HOME/.watchdog-report.log"
WATCHDOG_TIMEOUT=10
WATCHDOG_RETRIES=2

VERBOSE=false
export LC_NUMERIC=C

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $1" >>"$WATCHDOG_LOG"
}

info() {
    if [ "$VERBOSE" = true ]; then
        echo "$1"
    fi
}

while [[ "$#" -gt 0 ]]; do
    case $1 in
        -v|--verbose) VERBOSE=true ;;
        -h|--help)
            sed -n '2,/^$/s/^# \?//p' "$0"
            exit 0
            ;;
        *) echo "Unknown option: $1" >&2; exit 0 ;;
    esac
    shift
done

if [ -z "$WATCHDOG_API_KEY" ]; then
    log "SKIP: WATCHDOG_API_KEY not set"
    exit 0
fi

HOSTNAME=$(hostname | sed 's/\.local$//')
info "Collecting metrics for $HOSTNAME..."

# --- Disk ---
collect_disk() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        /bin/df -k | grep -vE '^Filesystem|tmpfs|devfs|map ' | grep -v '/System/Volumes' | awk '$1 ~ /^\/dev\// {
            total=$2*1024; used=$3*1024; pct=$5+0;
            gsub(/%/,"",pct);
            printf "{\"mount\":\"%s\",\"total\":%s,\"used\":%s,\"percent\":%d},", $9, total, used, pct
        }'
    else
        /bin/df -B1 --output=target,size,used,pcent | tail -n +2 | grep -vE 'tmpfs|devtmpfs|udev|snap' | awk '{
            pct=$4+0; gsub(/%/,"",pct);
            printf "{\"mount\":\"%s\",\"total\":%s,\"used\":%s,\"percent\":%d},", $1, $2, $3, pct
        }'
    fi
}

DISK_JSON=$(collect_disk | sed 's/,$//')
info "Disk: [$DISK_JSON]"

# --- Memory ---
collect_memory() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        # macOS: use vm_stat and sysctl
        PAGE_SIZE=$(sysctl -n hw.pagesize)
        TOTAL=$(sysctl -n hw.memsize)
        VM_STAT=$(vm_stat)
        FREE_PAGES=$(echo "$VM_STAT" | awk '/Pages free/ {gsub(/\./,"",$3); print $3}')
        INACTIVE_PAGES=$(echo "$VM_STAT" | awk '/Pages inactive/ {gsub(/\./,"",$3); print $3}')
        SPECULATIVE_PAGES=$(echo "$VM_STAT" | awk '/Pages speculative/ {gsub(/\./,"",$3); print $3}')
        AVAILABLE=$(( (FREE_PAGES + INACTIVE_PAGES + SPECULATIVE_PAGES) * PAGE_SIZE ))
        USED=$(( TOTAL - AVAILABLE ))
        # macOS swap: "total = 10240.00M  used = 8657.69M  free = 1582.31M"
        SWAP_INFO=$(sysctl -n vm.swapusage 2>/dev/null)
        SWAP_TOTAL=$(echo "$SWAP_INFO" | awk '{gsub(/M/,"",$3); printf "%.0f", $3*1048576}')
        SWAP_USED=$(echo "$SWAP_INFO" | awk '{gsub(/M/,"",$6); printf "%.0f", $6*1048576}')
    else
        # Linux: use /proc/meminfo
        TOTAL=$(awk '/^MemTotal/ {printf "%.0f", $2*1024}' /proc/meminfo)
        AVAILABLE=$(awk '/^MemAvailable/ {printf "%.0f", $2*1024}' /proc/meminfo)
        USED=$(( TOTAL - AVAILABLE ))
        SWAP_TOTAL=$(awk '/^SwapTotal/ {printf "%.0f", $2*1024}' /proc/meminfo)
        SWAP_USED=$(awk '/^SwapFree/ {printf "%.0f", $2*1024}' /proc/meminfo)
        SWAP_USED=$(( SWAP_TOTAL - SWAP_USED ))
    fi

    printf '{"total":%s,"used":%s,"available":%s,"swap_total":%s,"swap_used":%s}' \
        "${TOTAL:-0}" "${USED:-0}" "${AVAILABLE:-0}" "${SWAP_TOTAL:-0}" "${SWAP_USED:-0}"
}

MEMORY_JSON=$(collect_memory)
info "Memory: $MEMORY_JSON"

# --- CPU ---
collect_cpu() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        CORES=$(sysctl -n hw.ncpu)
        CPU_USAGE=$(ps -A -o %cpu | awk '{sum+=$1} END {printf "%.1f", sum/'"$CORES"'}')
        read LOAD1 LOAD5 LOAD15 <<< $(sysctl -n vm.loadavg | awk '{print $2, $3, $4}')
    else
        CORES=$(nproc)
        # Sample /proc/stat for ~1 second
        read -r _ u1 n1 s1 i1 w1 _ < /proc/stat
        sleep 1
        read -r _ u2 n2 s2 i2 w2 _ < /proc/stat
        ACTIVE=$(( (u2+n2+s2) - (u1+n1+s1) ))
        IDLE=$(( i2 - i1 ))
        TOTAL_DIFF=$(( ACTIVE + IDLE + (w2-w1) ))
        if [ "$TOTAL_DIFF" -gt 0 ]; then
            CPU_USAGE=$(awk "BEGIN {printf \"%.1f\", $ACTIVE * 100.0 / $TOTAL_DIFF}")
        else
            CPU_USAGE="0.0"
        fi
        read LOAD1 LOAD5 LOAD15 _ < /proc/loadavg
    fi

    printf '{"usage_percent":%s,"load_1m":%s,"load_5m":%s,"load_15m":%s,"cores":%d}' \
        "$CPU_USAGE" "$LOAD1" "$LOAD5" "$LOAD15" "$CORES"
}

CPU_JSON=$(collect_cpu)
info "CPU: $CPU_JSON"

# --- Services ---
collect_services() {
    if [ -z "$WATCHDOG_SERVICES" ]; then
        return
    fi

    IFS=',' read -ra SERVICES <<< "$WATCHDOG_SERVICES"
    local result=""
    for svc in "${SERVICES[@]}"; do
        svc=$(echo "$svc" | xargs) # trim whitespace
        if [[ "$OSTYPE" == "darwin"* ]]; then
            if pgrep -x "$svc" >/dev/null 2>&1; then
                running="true"
            else
                running="false"
            fi
        else
            if systemctl is-active --quiet "$svc" 2>/dev/null; then
                running="true"
            else
                running="false"
            fi
        fi
        result="${result}{\"name\":\"$svc\",\"running\":$running},"
    done
    echo "$result" | sed 's/,$//'
}

SERVICES_JSON=$(collect_services)
info "Services: [$SERVICES_JSON]"

# --- Processes (state counts) ---
# Sets PROC_TOTAL, PROC_RUNNING, PROC_SLEEPING, PROC_STOPPED, PROC_ZOMBIE
# so we can build both the top-level `processes` object (total/zombie for
# threshold alerts) and the richer breakdown inside `custom.processes`.
collect_processes() {
    local states
    PROC_TOTAL=""
    PROC_RUNNING=""
    PROC_SLEEPING=""
    PROC_STOPPED=""
    PROC_ZOMBIE=""

    if [[ "$OSTYPE" == "darwin"* ]]; then
        states=$(ps -Ao state= 2>/dev/null)
    else
        states=$(ps -eo state= 2>/dev/null)
    fi

    [ -z "$states" ] && return

    PROC_TOTAL=$(printf '%s\n' "$states" | wc -l | awk '{print $1}')
    PROC_RUNNING=$(printf '%s\n' "$states" | grep -c '^R' || true)
    PROC_SLEEPING=$(printf '%s\n' "$states" | grep -cE '^[SD]' || true)
    PROC_STOPPED=$(printf '%s\n' "$states" | grep -c '^T' || true)
    PROC_ZOMBIE=$(printf '%s\n' "$states" | grep -c '^Z' || true)
}

collect_processes

PROCESSES_JSON=""
PROCESSES_DETAIL_JSON=""
if [ -n "$PROC_TOTAL" ]; then
    PROCESSES_JSON=$(printf '{"total":%d,"zombie":%d}' "$PROC_TOTAL" "$PROC_ZOMBIE")
    PROCESSES_DETAIL_JSON=$(printf '{"total":%d,"running":%d,"sleeping":%d,"stopped":%d,"zombie":%d}' \
        "$PROC_TOTAL" "$PROC_RUNNING" "$PROC_SLEEPING" "$PROC_STOPPED" "$PROC_ZOMBIE")
fi
info "Processes: $PROCESSES_JSON"
info "Processes (detail): $PROCESSES_DETAIL_JSON"

# --- Top processes (by CPU and memory) ---
# Parses "pid pcpu pmem comm..." lines into JSON objects.
# comm is basenamed (macOS gives full path) and truncated to 30 chars.
format_top_processes() {
    awk '{
        pid=$1; cpu=$2; mem=$3;
        name=$4;
        for (i=5; i<=NF; i++) name = name " " $i;
        n = split(name, parts, "/");
        name = parts[n];
        gsub(/"/, "\\\"", name);
        gsub(/\\/, "\\\\", name);
        if (length(name) > 30) name = substr(name, 1, 30);
        printf "{\"pid\":%d,\"name\":\"%s\",\"cpu_percent\":%s,\"mem_percent\":%s},", pid, name, cpu, mem
    }' | sed 's/,$//'
}

collect_top_cpu() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        ps -Ao pid=,pcpu=,pmem=,comm= -r 2>/dev/null | head -5 | format_top_processes
    else
        ps -eo pid,pcpu,pmem,comm --sort=-pcpu --no-headers 2>/dev/null | head -5 | format_top_processes
    fi
}

collect_top_mem() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        ps -Ao pid=,pcpu=,pmem=,comm= -m 2>/dev/null | head -5 | format_top_processes
    else
        ps -eo pid,pcpu,pmem,comm --sort=-pmem --no-headers 2>/dev/null | head -5 | format_top_processes
    fi
}

TOP_CPU_JSON=$(collect_top_cpu)
TOP_MEM_JSON=$(collect_top_mem)
info "Top CPU: [$TOP_CPU_JSON]"
info "Top Mem: [$TOP_MEM_JSON]"

# --- System health (Linux-focused) ---
collect_uptime() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        # kern.boottime prints: "{ sec = 1712345678, usec = 123456 } ..."
        local boot now
        boot=$(sysctl -n kern.boottime 2>/dev/null | sed -nE 's/^\{ sec = ([0-9]+).*/\1/p')
        now=$(date +%s)
        [ -n "$boot" ] && echo $(( now - boot ))
    else
        awk '{print int($1)}' /proc/uptime 2>/dev/null
    fi
}

collect_failed_units() {
    if command -v systemctl >/dev/null 2>&1; then
        systemctl --failed --no-legend 2>/dev/null | wc -l | awk '{print $1}'
    else
        echo 0
    fi
}

collect_reboot_required() {
    if [ -f /var/run/reboot-required ]; then
        echo "true"
    else
        echo "false"
    fi
}

collect_oom_kills() {
    # Count OOM-killer events in the kernel log over the last hour.
    # journalctl -k is preferred (works without root if user is in systemd-journal);
    # falls back to readable kern.log, else 0.
    local count=0
    if command -v journalctl >/dev/null 2>&1; then
        count=$(journalctl -k --since "1 hour ago" 2>/dev/null | grep -c -i "out of memory" || true)
    elif [ -r /var/log/kern.log ]; then
        count=$(grep -c -i "out of memory" /var/log/kern.log 2>/dev/null || true)
    fi
    echo "${count:-0}"
}

SYSTEM_JSON=""
if [[ "$OSTYPE" != "darwin"* ]]; then
    UPTIME_S=$(collect_uptime)
    FAILED_UNITS=$(collect_failed_units)
    REBOOT_REQ=$(collect_reboot_required)
    OOM_KILLS=$(collect_oom_kills)
    SYSTEM_JSON=$(printf '{"uptime_seconds":%s,"failed_units":%s,"reboot_required":%s,"oom_kills_1h":%s}' \
        "${UPTIME_S:-0}" "${FAILED_UNITS:-0}" "${REBOOT_REQ:-false}" "${OOM_KILLS:-0}")
else
    UPTIME_S=$(collect_uptime)
    [ -n "$UPTIME_S" ] && SYSTEM_JSON=$(printf '{"uptime_seconds":%s}' "$UPTIME_S")
fi
info "System: $SYSTEM_JSON"

# --- Temperature ---
# Reads /sys/class/hwmon/*/tempN_input (millidegrees C) on Linux.
# Falls back to osx-cpu-temp on macOS if present. Skips empty sensors.
# Emits cpu_c (coretemp Package id 0 if available), max_c across all readings,
# and a zones array. Returns nothing if no usable sensors exist.
collect_temperature() {
    local zones cpu_c max_c

    if [[ "$OSTYPE" == "darwin"* ]]; then
        if command -v osx-cpu-temp >/dev/null 2>&1; then
            local val
            val=$(osx-cpu-temp 2>/dev/null | awk '{gsub(/°C/,""); v=$1+0; if (v>0) printf "%.1f", v}')
            if [ -n "$val" ]; then
                printf '{"cpu_c":%s,"max_c":%s,"zones":[{"name":"cpu","value_c":%s}]}' \
                    "$val" "$val" "$val"
            fi
        fi
        return
    fi

    zones=""
    cpu_c=""
    max_c=""

    for h in /sys/class/hwmon/hwmon*; do
        [ -d "$h" ] || continue
        local hname
        hname=$(cat "$h/name" 2>/dev/null)
        [ -z "$hname" ] && hname="hwmon"
        for tf in "$h"/temp*_input; do
            [ -f "$tf" ] || continue
            local raw val idx label fullname
            raw=$(cat "$tf" 2>/dev/null)
            [ -z "$raw" ] && continue
            [ "$raw" = "0" ] && continue
            val=$(awk "BEGIN {printf \"%.1f\", $raw/1000}")
            idx=$(basename "$tf" | sed 's/temp\([0-9]*\)_input/\1/')
            label=$(cat "$h/temp${idx}_label" 2>/dev/null)
            if [ -n "$label" ]; then
                fullname="$hname/$label"
            else
                fullname="$hname/temp$idx"
            fi
            # Escape backslashes and quotes for JSON
            fullname=${fullname//\\/\\\\}
            fullname=${fullname//\"/\\\"}
            zones="${zones}{\"name\":\"$fullname\",\"value_c\":$val},"
            if [ -z "$cpu_c" ] && [ "$hname" = "coretemp" ] && [ "$label" = "Package id 0" ]; then
                cpu_c="$val"
            fi
            if [ -z "$max_c" ]; then
                max_c="$val"
            else
                max_c=$(awk "BEGIN {print ($val > $max_c) ? $val : $max_c}")
            fi
        done
    done

    # Fallback: /sys/class/thermal if hwmon produced nothing
    if [ -z "$zones" ]; then
        for z in /sys/class/thermal/thermal_zone*; do
            [ -d "$z" ] || continue
            local t raw val
            t=$(cat "$z/type" 2>/dev/null)
            raw=$(cat "$z/temp" 2>/dev/null)
            [ -z "$raw" ] && continue
            [ "$raw" = "0" ] && continue
            val=$(awk "BEGIN {printf \"%.1f\", $raw/1000}")
            zones="${zones}{\"name\":\"${t:-zone}\",\"value_c\":$val},"
            if [ -z "$cpu_c" ] && [ "$t" = "x86_pkg_temp" ]; then
                cpu_c="$val"
            fi
            if [ -z "$max_c" ]; then
                max_c="$val"
            else
                max_c=$(awk "BEGIN {print ($val > $max_c) ? $val : $max_c}")
            fi
        done
    fi

    [ -z "$zones" ] && return

    zones=${zones%,}
    local result="{"
    [ -n "$cpu_c" ] && result="${result}\"cpu_c\":$cpu_c,"
    result="${result}\"max_c\":$max_c,\"zones\":[$zones]}"
    printf '%s' "$result"
}

TEMPERATURE_JSON=$(collect_temperature)
info "Temperature: $TEMPERATURE_JSON"

# --- Build custom block ---
CUSTOM_PARTS=()
[ -n "$PROCESSES_DETAIL_JSON" ] && CUSTOM_PARTS+=("\"processes\":$PROCESSES_DETAIL_JSON")
[ -n "$TOP_CPU_JSON" ]     && CUSTOM_PARTS+=("\"top_cpu\":[$TOP_CPU_JSON]")
[ -n "$TOP_MEM_JSON" ]     && CUSTOM_PARTS+=("\"top_mem\":[$TOP_MEM_JSON]")
[ -n "$SYSTEM_JSON" ]      && CUSTOM_PARTS+=("\"system\":$SYSTEM_JSON")
[ -n "$TEMPERATURE_JSON" ] && CUSTOM_PARTS+=("\"temperature\":$TEMPERATURE_JSON")

CUSTOM_JSON=""
if [ ${#CUSTOM_PARTS[@]} -gt 0 ]; then
    CUSTOM_JSON="{$(IFS=,; echo "${CUSTOM_PARTS[*]}")}"
fi

# --- Build payload ---
PAYLOAD="{\"hostname\":\"$HOSTNAME\""
PAYLOAD="$PAYLOAD,\"disk\":[$DISK_JSON]"
PAYLOAD="$PAYLOAD,\"memory\":$MEMORY_JSON"
PAYLOAD="$PAYLOAD,\"cpu\":$CPU_JSON"

if [ -n "$SERVICES_JSON" ]; then
    PAYLOAD="$PAYLOAD,\"services\":[$SERVICES_JSON]"
fi

if [ -n "$PROCESSES_JSON" ]; then
    PAYLOAD="$PAYLOAD,\"processes\":$PROCESSES_JSON"
fi

if [ -n "$CUSTOM_JSON" ]; then
    PAYLOAD="$PAYLOAD,\"custom\":$CUSTOM_JSON"
fi

PAYLOAD="$PAYLOAD}"

info "Payload: $PAYLOAD"

# --- Send report ---
RESPONSE_BODY=$(mktemp)
HTTP_CODE=$(curl -s -L -o "$RESPONSE_BODY" -w "%{http_code}" \
    -X POST "$WATCHDOG_URL" \
    -H "Content-Type: application/json" \
    -H "x-api-key: $WATCHDOG_API_KEY" \
    -m "$WATCHDOG_TIMEOUT" \
    --retry "$WATCHDOG_RETRIES" \
    --retry-delay 1 \
    --retry-connrefused \
    -d "$PAYLOAD" 2>>"$WATCHDOG_LOG")

if [ "$HTTP_CODE" = "200" ]; then
    log "OK: report sent for $HOSTNAME"
    info "Report sent successfully (HTTP $HTTP_CODE)"
else
    log "WARN: report for $HOSTNAME — HTTP $HTTP_CODE"
    log "  Payload: $PAYLOAD"
    log "  Response: $(cat "$RESPONSE_BODY")"
    info "Report failed (HTTP $HTTP_CODE)"
fi
rm -f "$RESPONSE_BODY"

exit 0
