#!/usr/bin/env bash

run_nvim() {
	if [ $# -eq 0 ]; then
		nvim .
	else
		nvim "$1"
	fi
}

# git
alias gs='git status'
alias gm='git merge --no-ff'
alias gmf='git merge --ff-only'
alias ga='git commit --amend --no-edit;'
alias gap='git commit --amend --no-edit; git push -f origin HEAD --no-verify'
alias gp='git push origin HEAD && git push --tags'
alias gcontrib='git shortlog -s -n'

# Modern CLI replacements (fall back to classic if not installed)
command -v eza   &>/dev/null && alias ls='eza --icons --group-directories-first' && alias la='eza -la --icons --group-directories-first' && alias lt='eza --tree --icons --level=2'
command -v bat   &>/dev/null && alias cat='bat --paging=never' && alias catp='bat'
command -v fd    &>/dev/null && alias find='fd'
command -v dust  &>/dev/null && alias du='dust'
command -v btop  &>/dev/null && alias top='btop'
command -v delta &>/dev/null && alias diff='delta'

# ls
if ! command -v eza &>/dev/null; then
  alias l="ls -lF ${colorflag}"
  alias la='ls -la'
fi
alias dun='list-space' # easier to type

# cd
alias cdh='cd ~/'
alias cddrop='cd ~/Dropbox'
alias cddev='cd ~/dev'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

alias d="cd ~/Dropbox"
alias dl="cd ~/Downloads"

# docker
alias dm='docker-machine'
alias up='docker-compose up'

# Other util
alias his='history | grep $1'
alias grep='grep --color=auto'
alias dockerips='docker inspect -f "{{.Name}} - {{.NetworkSettings.IPAddress }}" $(docker ps -aq)'
alias n=run_nvim
alias path='echo -e ${PATH//:/\\n}'
alias e=exit
alias mux='tmuxinator'
alias kk='kill %1'

# IP addresses
alias ip="dig +short myip.opendns.com @resolver1.opendns.com"
